# ── AI Provider ───────────────────────────────────────────────
# Options: lmstudio | groq | gemini | ollama
AI_PROVIDER=lmstudio

# LM Studio — local Gemma 3
# Make sure LM Studio is running with a model loaded
# LM Studio server: http://127.0.0.1:1234
# The model name must match exactly what LM Studio shows in its UI
AI_MODEL=gemma-3-12b-it

# ── Vision Provider ───────────────────────────────────────────
# Options: gemini | ollama
# (lmstudio vision support depends on loaded model — use gemini for reliability)
VISION_PROVIDER=gemini
VISION_MODEL=gemini-2.5-flash

# ── API Keys ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIzaSy...

# --- LangSmith Runtime Tracing Tracking ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_sane_trace_placeholder
LANGCHAIN_PROJECT=project-sane

# ── OpenRouter Failover Gateway Configuration ──────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-failover_placeholder_key
OPENROUTER_MODEL=google/gemini-2.5-flash
